        "bl_custom_html_css_js_liquid_block_code_fbJRJK": {
          "type": "shopify://apps/bl-custom-html-css-js-liquid/blocks/block-code/96fc73ef-2727-4174-82ec-12cfce5b3426",
          "settings": {
            "html_code": "",
            "css_code": "",
            "js_code": "",
            "liquid_code": "<div class=\"t4s-liquid_custom_liquid_mQfdP8 t4s-pr__custom-liquid t4s-rte--list\">\n  <style>\n    .coupon-copy {\n      cursor: pointer;\n      display: inline-block;\n      line-height: 1;\n      padding: 4px 5px 6px 5px;\n      border-radius: 5px;\n      color: #fff1f1;\n      background-color: #fe9323;\n    }\n  </style>\n  <div class=\"product-form__custom-liquid\">\n    <div style=\"\n        border: 0px dashed;\n        min-height: 50px;\n        width: 100%;\n        color: black;\n        padding: rem;\n        font-size: 16px;\n      \">\n      <a style=\"color: #f64a00; font-weight: 600\" plerdy-tracking-id=\"76061976401\"></a>\n      <p style=\"color: black\"></p>\n      <p>\n        <a style=\"color: #000\" plerdy-tracking-id=\"45244727501\" class=\"discount-text\">🔥 All Products Get 10% off</a> \n        <span class=\"code-text\">Code:</span>\n        <a style=\"color: #000\" plerdy-tracking-id=\"17481893501\" class=\"coupon-code\">SD10</a>\n        <span data-code=\"OOD10\" class=\"coupon-copy\" onclick=\"copyCode(event);\" style=\"float: right\" plerdy-tracking-id=\"27551823001\">copy</span>\n    </div>\n    <script>\n      // 语言映射表\n      const translations = {\n        en: {\n          discountText: \"🔥 Buy 1 Get 10% off\",\n          codeText: \"Code:\",\n          copyText: \"copy\",\n          copiedText: \"copied!\"\n          discountText: \"🔥 Buy 2 Get 13% off\",\n          codeText: \"Code:\",\n          copyText: \"copy\",\n          copiedText: \"copied!\"\n        },\n        de: {\n          discountText: \"✅ 10% Rabatt auf alle Produkte!\",\n          codeText: \"Code:\",\n          copyText: \"kopieren\",\n          copiedText: \"kopiert!\"\n        }\n      };\n\n      // 检测页面语言并更新文本\n      function updateLanguage() {\n        const lang = document.documentElement.lang || 'en';\n        const translation = translations[lang] || translations['en'];\n        \n        // 更新折扣文本\n        const discountTexts = document.querySelectorAll('.discount-text');\n        discountTexts.forEach(el => el.textContent = translation.discountText);\n        \n        // 更新\"Code:\"文本\n        const codeTexts = document.querySelectorAll('.code-text');\n        codeTexts.forEach(el => el.textContent = translation.codeText);\n        \n        // 更新\"copy\"按钮文本\n        const copyButtons = document.querySelectorAll('.coupon-copy');\n        copyButtons.forEach(el => el.textContent = translation.copyText);\n      }\n\n      // 复制到剪贴板\n      function copyToClipboard(str) {\n        let el = document.createElement(\"textarea\");\n        el.value = str;\n        el.setAttribute(\"readonly\", \"\");\n        el.style.position = \"absolute\";\n        el.style.left = \"-9999px\";\n        document.body.appendChild(el);\n        let selected =\n          document.getSelection().rangeCount > 0\n            ? document.getSelection().getRangeAt(0)\n            : false;\n        el.select();\n        document.execCommand(\"copy\");\n        document.body.removeChild(el);\n        if (selected) {\n          document.getSelection().removeAllRanges();\n          document.getSelection().addRange(selected);\n        }\n      }\n\n      // 复制折扣码\n      function copyCode(e) {\n        let $this = e.target;\n        copyToClipboard($this.getAttribute(\"data-code\"));\n        \n        const lang = document.documentElement.lang || 'en';\n        const translation = translations[lang] || translations['en'];\n        \n        $this.innerText = translation.copiedText;\n        setTimeout(function () {\n          $this.innerText = translation.copyText;\n        }, 1500);\n      }\n\n      // 页面加载时更新语言\n      document.addEventListener('DOMContentLoaded', updateLanguage);\n    </script>\n  </div>\n</div>"
          }
        },
