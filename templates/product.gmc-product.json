        "custom_code_block_hi6AxG": {
          "type": "custom_code_block",
          "settings": {
            "custom_code": "<p><span style=\"font-size: 18px; font-family: Fairplay Display;color:black;\">Design Inspiration</span></p>\n<p><span style=\"font-size: 14px; font-family: Montserrat;color:black;\">The Hanton Collection draws its inspiration from the order of modern architecture and the strength of industrial design.<br>Crafted from metal, ceramic, and glass, its subtle angular details balance durability with minimalist elegance.<br>Available in a variety of finishes, Hanton adapts effortlessly to different interiors—whether in the living room, dining area, or even the bathroom, thanks to its damp rating.<br>More than just lighting, it embodies an industrial-modern lifestyle: understated, rational, and built to last.</span></p>"
          }
        },
