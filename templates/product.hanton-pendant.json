            "delivery_return_heading": "Shipping info",
            "delivery_return_content": "<p><b>Return Policy:</b> We will gladly accept returns for any reason within 30 days of receipt of delivery.</p>\n\n<p><b>Availability:</b> Ships anywhere in the United States</p>\n\n<p><b>Processing Time:</b> Allow 3-4 business days processing time for your order to ship.</p>",
            "social_sharing_products": true,
