{%- assign card_image = product.featured_media.preview_image -%}
{%- assign card_url = product.url -%}
{%- assign card_variant = product.selected_or_first_available_variant -%}
{%- assign card_on_sale = false -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign card_on_sale = true -%}
{%- endif -%}

<article class="sdh-product-card">
  <a class="sdh-product-card__media" href="{{ card_url }}" aria-label="{{ product.title | escape }}">
    {%- if card_on_sale -%}
      {%- assign card_saved = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
      <span class="sdh-product-card__badge">-{{ card_saved }}%</span>
    {%- endif -%}
    {%- if card_image != blank -%}
      {{ card_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'sdh-product-card__image', widths: '360, 540, 720, 900', sizes: '(min-width: 1200px) 24vw, (min-width: 768px) 45vw, 92vw' }}
    {%- else -%}
      <span class="sdh-product-card__placeholder">{{ 'product-1' | placeholder_svg_tag }}</span>
    {%- endif -%}
  </a>
  <div class="sdh-product-card__body">
    <a class="sdh-product-card__title" href="{{ card_url }}">{{ product.title }}</a>
    <div class="sdh-product-card__meta">
      <span class="sdh-product-card__price">{{ product.price | money }}</span>
      {%- if card_on_sale -%}
        <span class="sdh-product-card__compare">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
    <a class="sdh-product-card__link" href="{{ card_url }}">
      {%- if product.available -%}
        View product
      {%- else -%}
        Sold out
      {%- endif -%}
    </a>
  </div>
</article>
