{%- liquid
  if section.settings.fullwidth
    assign container = 'container-full'
  elsif section.settings.max_width != blank
    assign container = 'bwp-container'
  else
    assign container = 'container'
  endif

  assign max_width = ''
  if section.settings.fullwidth == false and section.settings.max_width != blank
    capture max_width
      echo 'style="max-width: ' | append: section.settings.max_width | append: ';"'
    endcapture
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .sd-collection-quick-links-section {
    margin: {{ section.settings.margin }};
  }
{%- endstyle -%}

{%- if section.settings.show -%}
  <section class="wpbingo-section sd-collection-quick-links-section wpbingo-section--{{ section.id }}">
    <div class="{{ container }}" {{ max_width }}>
      <div class="sd-collection-quick-links" aria-label="{{ section.settings.aria_label | escape }}">
        <div class="sd-collection-quick-links__heading">
          {%- if section.settings.eyebrow != blank -%}
            <span class="sd-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <span class="sd-title">{{ section.settings.heading }}</span>
          {%- endif -%}
          {%- if section.settings.copy != blank -%}
            <span class="sd-copy">{{ section.settings.copy }}</span>
          {%- endif -%}
        </div>

        <div class="sd-collection-quick-links__rail" role="list">
          {%- for block in section.blocks -%}
            {%- liquid
              assign card_collection = block.settings.collection
              assign card_url = block.settings.link
              assign card_title = block.settings.title
              assign card_caption = block.settings.caption
              assign card_image = block.settings.image

              if card_collection != blank
                assign card_url = card_collection.url
                if card_title == blank
                  assign card_title = card_collection.title
                endif
                if card_image == blank and card_collection.image != blank
                  assign card_image = card_collection.image
                endif
              endif

              if card_url == blank
                assign card_url = '#'
              endif

              assign image_alt = card_image.alt | default: card_title
            -%}
            <a class="sd-collection-link-card" href="{{ card_url }}" role="listitem" {{ block.shopify_attributes }}>
              <span class="sd-collection-link-card__image">
                {%- if card_image != blank -%}
                  {{ card_image | image_url: width: 520 | image_tag: loading: 'lazy', sizes: '(min-width: 1200px) 210px, (min-width: 750px) 22vw, 48vw', alt: image_alt }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'sd-collection-link-card__placeholder' }}
                {%- endif -%}
              </span>
              <span class="sd-collection-link-card__body">
                {%- if card_title != blank -%}
                  <span class="sd-collection-link-card__title">{{ card_title }}</span>
                {%- endif -%}
                {%- if card_caption != blank -%}
                  <span class="sd-collection-link-card__caption">{{ card_caption }}</span>
                {%- endif -%}
              </span>
            </a>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "SD Collection Quick Links",
  "class": "wpbingo-framework",
  "settings": [
    {
      "type": "checkbox",
      "id": "show",
      "label": "Show section",
      "default": true
    },
    {
      "type": "text",
      "id": "max_width",
      "label": "Width container",
      "default": "1750px"
    },
    {
      "type": "checkbox",
      "id": "fullwidth",
      "label": "Fullwidth",
      "default": false
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Margin",
      "default": "10px 0 28px 0"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Shop lighting by room"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by room"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find the right light faster"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Use these scene shortcuts before filtering by price, availability, finish, or fixture type."
    }
  ],
  "blocks": [
    {
      "type": "quick_link",
      "name": "Quick link",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Living Room"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Layered ambient light"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Fallback link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SD Collection Quick Links",
      "blocks": [
        { "type": "quick_link" },
        { "type": "quick_link" },
        { "type": "quick_link" },
        { "type": "quick_link" }
      ]
    }
  ]
}
{% endschema %}
