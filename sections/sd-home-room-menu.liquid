{%- assign max_width = section.settings.max_width | default: '1750px' -%}
<section class="sdh sdh-section" style="--sdh-max: {{ max_width | escape }};">
  <div class="sdh-wrap">
    <div class="sdh-section__head">
      <div>
        <p class="sdh-kicker">{{ section.settings.eyebrow }}</p>
        <h2 class="sdh-title">{{ section.settings.heading }}</h2>
      </div>
      <p class="sdh-copy">{{ section.settings.copy }}</p>
    </div>

    <div class="sdh-room-layout">
      <div class="sdh-room-grid">
        {%- for block in section.blocks -%}
          {%- if block.settings.group == 'room' -%}
            <a class="sdh-room-card" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
              <span class="sdh-card-media">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '420, 640, 900', sizes: '(min-width: 1200px) 20vw, (min-width: 768px) 31vw, 92vw' }}
                {%- else -%}
                  <span class="sdh-image-fallback">{{ 'collection-2' | placeholder_svg_tag }}</span>
                {%- endif -%}
              </span>
              <span class="sdh-card-body">
                <span class="sdh-card-title">{{ block.settings.title }}</span>
                <span class="sdh-card-caption">{{ block.settings.caption }}</span>
              </span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <aside class="sdh-menu-panel" aria-label="Lighting menu shortcuts">
        {%- assign groups = 'room|By Room,type|By Type,style|By Style' | split: ',' -%}
        {%- for group_pair in groups -%}
          {%- assign group_data = group_pair | split: '|' -%}
          <div class="sdh-menu-group">
            <h3>{{ group_data[1] }}</h3>
            <div class="sdh-menu-links">
              {%- for block in section.blocks -%}
                {%- if block.settings.group == group_data[0] -%}
                  <a class="sdh-menu-link" href="{{ block.settings.link | default: '#' }}">{{ block.settings.title }}</a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      </aside>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SD Home Room Menu",
  "settings": [
    {
      "type": "text",
      "id": "max_width",
      "label": "Content width",
      "default": "1750px"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Lighting by room"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose the space first, then narrow the edit."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "This mirrors how customers shop: project first, product category second."
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu item",
      "settings": [
        {
          "type": "select",
          "id": "group",
          "label": "Group",
          "options": [
            {
              "value": "room",
              "label": "By Room"
            },
            {
              "value": "type",
              "label": "By Type"
            },
            {
              "value": "style",
              "label": "By Style"
            }
          ],
          "default": "room"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Living Room"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "A concise reason to shop this path."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SD Home Room Menu"
    }
  ]
}
{% endschema %}
