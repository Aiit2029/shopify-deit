{%- assign max_width = section.settings.max_width | default: '1750px' -%}
{%- assign columns = section.settings.columns | default: '4' -%}
<section class="sdh sdh-section{% if section.settings.background == 'paper' %} sdh-section--paper{% endif %}" style="--sdh-max: {{ max_width | escape }};">
  <div class="sdh-wrap">
    <div class="sdh-section__head">
      <div>
        <p class="sdh-kicker">{{ section.settings.eyebrow }}</p>
        <h2 class="sdh-title">{{ section.settings.heading }}</h2>
      </div>
      <p class="sdh-copy">{{ section.settings.copy }}</p>
    </div>

    <div class="sdh-card-grid sdh-card-grid--{{ columns }}">
      {%- for block in section.blocks -%}
        <a class="sdh-image-card" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          <span class="sdh-card-media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '420, 640, 900', sizes: '(min-width: 1200px) 19vw, (min-width: 768px) 45vw, 92vw' }}
            {%- else -%}
              <span class="sdh-image-fallback">{{ 'collection-3' | placeholder_svg_tag }}</span>
            {%- endif -%}
          </span>
          <span class="sdh-card-body">
            <span class="sdh-card-title">{{ block.settings.title }}</span>
            <span class="sdh-card-caption">{{ block.settings.caption }}</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SD Home Card Grid",
  "settings": [
    {
      "type": "text",
      "id": "max_width",
      "label": "Content width",
      "default": "1750px"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        {
          "value": "canvas",
          "label": "Canvas"
        },
        {
          "value": "paper",
          "label": "Paper"
        }
      ],
      "default": "canvas"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Desktop columns",
      "options": [
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        }
      ],
      "default": "4"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by type"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Let the object set the rhythm."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Use this grid for category, homeware, or style edits."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pendant Lights"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "A concise reason to shop this path."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SD Home Card Grid"
    }
  ]
}
{% endschema %}
