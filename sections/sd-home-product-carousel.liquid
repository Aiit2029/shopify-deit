{%- assign max_width = section.settings.max_width | default: '1750px' -%}
{%- assign collection_handle = section.settings.collection -%}
{%- assign product_limit = section.settings.product_limit | default: 8 -%}
{%- assign selected_collection = collections[collection_handle] -%}
<section id="sdh-carousel-{{ section.id }}" class="sdh sdh-section{% if section.settings.theme == 'paper' %} sdh-section--paper{% elsif section.settings.theme == 'dark' %} sdh-section--dark{% endif %}" style="--sdh-max: {{ max_width | escape }};">
  <div class="sdh-wrap">
    <div class="sdh-product-head">
      <div class="sdh-section__head">
        <div>
          <p class="sdh-kicker">{{ section.settings.eyebrow }}</p>
          <h2 class="sdh-title">{{ section.settings.heading }}</h2>
        </div>
        <p class="sdh-copy">{{ section.settings.copy }}</p>
      </div>
      {%- if section.settings.show_arrows -%}
        <div class="sdh-carousel-controls" aria-label="Product carousel controls">
          <button class="sdh-carousel-button" type="button" data-sdh-carousel-prev aria-label="Previous products">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M15 5l-7 7 7 7"/></svg>
          </button>
          <button class="sdh-carousel-button" type="button" data-sdh-carousel-next aria-label="Next products">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    <div class="sdh-product-track" data-sdh-product-track>
      {%- if selected_collection != blank and selected_collection.products_count > 0 -%}
        {%- for product in selected_collection.products limit: product_limit -%}
          {% render 'sd-home-product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="sdh-product-placeholder">Connect a collection in this section.</div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="sdh-actions">
        <a class="sdh-button{% if section.settings.theme != 'dark' %} sdh-button--dark{% else %} sdh-button--light{% endif %}" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('sdh-carousel-{{ section.id }}');
    if (!root || root.dataset.sdhReady === 'true') return;
    root.dataset.sdhReady = 'true';
    var track = root.querySelector('[data-sdh-product-track]');
    var prev = root.querySelector('[data-sdh-carousel-prev]');
    var next = root.querySelector('[data-sdh-carousel-next]');
    if (!track || !prev || !next) return;
    var step = function () { return Math.max(track.clientWidth * 0.82, 280); };
    prev.addEventListener('click', function () { track.scrollBy({ left: -step(), behavior: 'smooth' }); });
    next.addEventListener('click', function () { track.scrollBy({ left: step(), behavior: 'smooth' }); });
  })();
</script>

{% schema %}
{
  "name": "SD Home Product Carousel",
  "settings": [
    {
      "type": "text",
      "id": "max_width",
      "label": "Content width",
      "default": "1750px"
    },
    {
      "type": "select",
      "id": "theme",
      "label": "Theme",
      "options": [
        {
          "value": "canvas",
          "label": "Canvas"
        },
        {
          "value": "paper",
          "label": "Paper"
        },
        {
          "value": "dark",
          "label": "Dark"
        }
      ],
      "default": "paper"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The shortlist customers return to."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "A focused product carousel keeps the page shoppable without turning it into a catalogue wall."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Product limit",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrow controls",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "SD Home Product Carousel"
    }
  ]
}
{% endschema %}
