{%- assign max_width = section.settings.max_width | default: '1750px' -%}
<section class="sdh sdh-hero" style="--sdh-max: {{ max_width | escape }};" aria-label="{{ section.settings.heading | escape }}">
  <div class="sdh-hero__media" aria-hidden="true">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2600 | image_tag: loading: 'eager', class: 'sdh-hero__image', widths: '900, 1300, 1800, 2200, 2600', sizes: '100vw' }}
    {%- else -%}
      <span class="sdh-hero__placeholder"></span>
    {%- endif -%}
  </div>
  <div class="sdh-wrap sdh-hero__content">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="sdh-kicker">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="sdh-heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.copy != blank -%}
        <p class="sdh-copy">{{ section.settings.copy }}</p>
      {%- endif -%}
      <div class="sdh-actions">
        {%- if section.settings.primary_label != blank -%}
          <a class="sdh-button sdh-button--light" href="{{ section.settings.primary_link | default: '#' }}">{{ section.settings.primary_label }}</a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a class="sdh-button" href="{{ section.settings.secondary_link | default: '#' }}">{{ section.settings.secondary_label }}</a>
        {%- endif -%}
      </div>
      {%- if section.blocks.size > 0 -%}
        <div class="sdh-hero-notes">
          {%- for block in section.blocks -%}
            <div class="sdh-hero-note" {{ block.shopify_attributes }}>
              <strong>{{ block.settings.title }}</strong>
              <span>{{ block.settings.copy }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SD Home Hero",
  "settings": [
    {
      "type": "text",
      "id": "max_width",
      "label": "Content width",
      "default": "1750px"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Summer Home Refresh"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start with the room. Finish with the right detail."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Shop Seendoor through the same choices a home project follows: room, lighting type, style, availability, and the finishing pieces around it."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Shop the summer edit"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Browse quick ship"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    }
  ],
  "blocks": [
    {
      "type": "note",
      "name": "Hero note",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Menu-first"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Start from the way the navigation is already organized."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SD Home Hero"
    }
  ]
}
{% endschema %}
