{% liquid
  if settings.smi_currency_code_enabled != nil
    assign currency_code_enabled = settings.smi_currency_code_enabled
  else
    assign currency_code_enabled = global_settings.showCurrencyCode | default: false
  endif
  assign target = product.selected_or_first_available_variant
  assign is_featured_product = false
  assign selectedVariantId = target.id
  assign compare_at_price = target.compare_at_price
  assign price = target.price | default: 1999
  assign selectedVariantTitle = target.title
  assign available = target.available | default: false
  assign money_price = price | money
  if currency_code_enabled
    assign money_price = price | money_with_currency
  endif
  if target == product and product.price_varies
    assign money_price = 'products.product.price.from_price_html' | t: price: money_price
  endif
  assign show_buy_quantity_btn = false
  assign has_buy_group = false
  assign has_color_block = false
  assign custom_color = 'smi-color-' | append: section.settings.color_scheme
  assign pos_guarantee = 0
  assign padding_bottom_gallery = false
  assign product_breadcrumb_block = section.blocks | where: 'type', 'product_breadcrumb' | first
  capture icon_arrow
    render 'smi-icons', icon: 'arrow-right'
  endcapture
%}
<div
  id="smi-{{ section.id }}"
  class="smi-{{ section.id }} smi-section__inner smi-gradient smi-section-product-detail {{ custom_color }} smi-overflow-x-clip"
  data-section="product-detail-free-1" data-name="✧Product detail free 1">
  
{% liquid
    if settings.smi_currency_code_enabled != nil
        assign currency_code_enabled = settings.smi_currency_code_enabled
    else
        assign currency_code_enabled = global_settings.showCurrencyCode | default: false
    endif
    if currency_code_enabled
        assign currency_full = true
    else
        assign currency_full = false
    endif
    assign target = product.selected_or_first_available_variant
    assign price_amount = product.price | money
    assign price_no_decimals = product.price | money_without_trailing_zeros
    assign has_money_decimals = true
    assign price_string = product.price | money
    assign decimal_part = price_string | split: '.' | last
    if cart.currency.iso_code == 'VND'
        if decimal_part == '00'
            assign has_money_decimals = false
        endif
    else
        assign decimal_part = price_string | split: ',' | last
        if decimal_part == '00'
            assign has_money_decimals = false
        endif
    endif
    %}
    {%-liquid
    if settings.smi_animations_reveal_on_scroll != nil
        assign animation_scroll = settings.smi_animations_reveal_on_scroll
    else
        assign global_settings = shop.metafields.smind.settings.value
        assign animation_scroll = global_settings.revealOnScroll
    endif
-%}
    <div class="smi-product-container {%- if section.settings.container_full_width %} smi-container-fluid{%- else %} smi-container{%- endif %}">
    {% if template == 'product' or template contains "product." %}
        {% if product_breadcrumb_block %}  
            <div class="smi-top-breadcrumb {% if product_breadcrumb_block.settings.breadcrumb_top %} smi-breadcrumb-showing-top{% endif %} {%- if animation_scroll %} smi-scroll-trigger smi-animate--slide-in {% endif -%}">
                {% assign path_style = product_breadcrumb_block.settings.path_style %}
                <div
  class="smi-product-detail-element smi-product-breadcrumb smi-pbg-info smi-w-100 smi-column-gap-xxs smi-align-items-center {% if product_breadcrumb_block.settings.breadcrumb_top %}smi-mb-lg{% else %}smi-breadcrumb-showing-top-mob smi-mt-lg{% endif %}"
  {{ block.shopify_attributes }}
>
{% capture icon_dot %}
  <svg class="smi-svg-icon smi-svg-dot" xmlns="http://www.w3.org/2000/svg" width="4" height="3" viewBox="0 0 4 3" fill="none">
    <circle cx="2.11816" cy="1.5" r="1.5" fill="#1F1F21" fill-opacity="0.55"/>
  </svg>
{% endcapture %}
  {% liquid
    assign collection = product.collections[0]
  %}
  <a class="smi-heading-breadcrumb-text-underline smi-text-md smi-d-inline-flex" href="{{ shop.url }}">{{ 'smind.general.home' | t }} {% if path_style == 'arrow' %}{{ icon_arrow }}{% else %} {{ icon_dot  }}{% endif %}</a>
  <a
    class="smi-heading-breadcrumb-text-underline smi-text-md smi-d-inline-flex"
    href="{%- if collection.url -%}{{ collection.url }}{% else %}{{ shop.url }}/products{% endif %}"
  >
    {%- if collection.url -%}{{ collection.title }}{% else %}{{ 'smind.product.product_lable' | t }}{% endif -%}
    {% if path_style == 'arrow' %}{{ icon_arrow }}{% else %}{{ icon_dot  }}{% endif %}
  </a>
  <span class="smi-heading-breadcrumb-text-content smi-text-color-55 smi-text-md">{{ product.title }}</span>
</div>
            </div>
        {% endif %}
    {% else %}
        {%-liquid
    if settings.smi_animations_reveal_on_scroll != nil
        assign animation_scroll = settings.smi_animations_reveal_on_scroll
    else
        assign global_settings = shop.metafields.smind.settings.value
        assign animation_scroll = global_settings.revealOnScroll
    endif
-%}
<div class="smi-heading-component smi-heading-component--align-{{section.settings.heading_alignment}} smi-link-wrapper" {{- block.shopify_attributes -}}    >
  {% liquid
    assign heading = section.settings.heading | strip
    assign sub_heading = section.settings.sub_heading | strip
    assign description = section.settings.description | strip
  %}
  <div class="smi-heading-inner
    {%- if animation_scroll %} smi-scroll-trigger smi-animate--slide-in{% endif -%}
    {%- if heading != blank or sub_heading != blank or description != blank %} smi-mb-xxl{% endif -%}
    ">
        {%- assign sub_heading = section.settings.sub_heading | strip -%}
{% if sub_heading != blank %}
    <p class="smi-text-sub smi-mb-xxs smi-heading-component__subheading" data-type="subheading" data-key="s.subheading">{{- sub_heading -}}</p>
{% endif %} 
        {%- assign description = section.settings.description | strip -%}
{%- assign heading = section.settings.heading | strip -%}
{% if heading != blank %}
    <h2 class="{{ section.settings.heading_size }} {% if description != blank %}smi-mb-sm{% endif %} smi-heading-component__heading" data-type="heading" data-key="s.heading">{{- heading -}}</h2>
{% endif %} 
        {%- assign description = section.settings.description | strip -%}
{% if description != blank %}
    <div class="smi-text-md smi-heading-component__description smi-format-content" data-type="description" data-key="s.description">{{ description }}</div>
{% endif %}
    </div>
</div>
    {% endif %}
    <div class="{%- liquid
    echo 'smi-product-container-content smi-d-flex smi-flex-wrap'
    if section.settings.desktop_media_position == 'right'
        echo ' smi-flex-md-row-reverse'
    endif
    if section.settings.enable_sticky_content_on_desktop
        echo ' smi-product-container-content--sticky'
    endif
    -%}">
    <div class="smi-column-1 smi-w-100 smi-w-md-50 smi-w-lg-{{ section.settings.desktop_media_width }}">
        <div class="smi-column-1__inner">
        <div class="smi-block-container-1 {% if padding_bottom_gallery %}smi-pb-xxl smi-pb-md-xl{% endif %} smi-pb-sm-xl">
{% liquid
  case section.settings.desktop_layout
    when 'left_thumbnails'
      assign desktop_layout = 'vertical-thumbnails'
    when 'bottom_thumbnails'
      assign desktop_layout = 'horizontal-thumbnails'
    when '2_columns'
      assign desktop_layout = 'grid-2-col'
    when '1_column'
      assign desktop_layout = 'grid-1-col'
    when 'highlight'
      assign desktop_layout = 'grid-highlight'
    when 'pagination'
      assign desktop_layout = 'pagination'
  endcase
  case section.settings.mobile_layout
    when 'hide_thumbnails'
      assign mobile_layout = 'pagination'
    when 'show_thumbnails'
      assign mobile_layout = 'horizontal-thumbnails'
    when '2_columns_carousel'
      assign mobile_layout = '2-columns-carousel'
  endcase
  capture icon_arrow
    render 'smi-icons', icon: 'arrow-right'
  endcapture
  capture icon_zoom
    render 'smi-icons', icon: 'zoom'
  endcapture
  capture icon_play
    render 'smi-icons', icon: 'play-button'
  endcapture
  capture icon_3d
    render 'smi-icons', icon: '3d'
  endcapture
  capture icon_plus
    render 'smi-icons', icon: 'plus'
  endcapture
  capture icon_minus
    render 'smi-icons', icon: 'minus'
  endcapture
%}
<style>
  {{ '#smi-' | append: section.id }}{
      --number-media: {{- product.media.size -}};
      {% liquid
          if product.media.size > 2
              assign item_width_layout_2_columns_carousel = 'calc((100% - 60px) / 2)'
          elsif product.media.size == 2
              assign item_width_layout_2_columns_carousel = 'calc((100% - 15px) / 2)'
          else
              assign item_width_layout_2_columns_carousel = '100%'
          endif
      %}
      --item-width-layout-2-columns-carousel: {{ item_width_layout_2_columns_carousel }};
  }
</style>
<div
  id="{{ section.id | append: '__gallery' }}"
  class="{%- liquid
    echo 'smi-product-gallery smi-media-wrapper'
    echo ' smi-media-fit-' | append: section.settings.constrain_media_to_screen_height
    echo ' smi-product-gallery--layout-' | append: mobile_layout
    echo ' smi-image-zoom-' | append: section.settings.image_zoom
    if section.settings.hide_variants
      echo ' smi-hide-variants'
    endif
  -%}
  "
  data-desktop-layout="{{- desktop_layout -}}"
  data-mobile-layout="{{- mobile_layout -}}"
  data-current-variant-id="{{ product.selected_or_first_available_variant.id }}"
>
  <script>
    (function(){
      const div = document.getElementById("{{ section.id | append: '__gallery' }}");
      let prefix = 'smi-product-gallery--layout-'
      let match = window.matchMedia("(min-width: 768px)").matches
      div.classList.toggle(prefix + "{{ mobile_layout }}", !match);
      div.classList.toggle(prefix + "{{ desktop_layout }}", match);
    })()
  </script>
  <div
    class="
      {%- liquid
        echo 'smi-product-gallery__inner'
        if section.settings.desktop_media_position == 'right' and desktop_layout == 'vertical-thumbnails'
          echo ' media-on-the-right'
        endif
      -%}
    "
  >
    {% if desktop_layout == 'vertical-thumbnails'
      or desktop_layout == 'horizontal-thumbnails'
      or mobile_layout == 'horizontal-thumbnails'
    %}
      {% assign has_thumbnail = true %}
      <div class="smi-product-gallery__thumbnail {% if mobile_layout != 'horizontal-thumbnails' %} smi-d-none{% endif %} smi-d-md-block">
    <div class="smi-swiper">
        <div class="smi-swiper-wrapper" data-current-variant="{{ product.selected_or_first_available_variant.id }}">
            <div class="smi-thumb smi-swiper-slide">
                <div class="smi-thumb__image">
                    <img src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/wcAAwAB/epJ5iYAAAAASUVORK5CYII=" alt="transparent image" width="88" height="100">
                </div>
            </div>
        </div>
    </div>
    <div class="smi-navigation__prev">
        {{ icon_arrow }}
    </div>
    <div class="smi-navigation__next"> 
        {{ icon_arrow }}
    </div>
</div>
    {% else %}
      {% assign has_thumbnail = false %}
    {% endif %}
    <div class="smi-product-gallery__slider">
      <div class="smi-swiper {%- if section.settings.media_full_width %} smi-slide-xs-full-width{% endif -%}">
        {%- liquid
  if variant_images.size == product.media.size
    assign single_media_visible = true
  endif
  assign media_count = product.media.size
  if media_count == 1 or single_media_visible
    assign single_media_visible_mobile = true
  endif
  if section.settings.video_looping == true
    assign video_looping = 1
  else
    assign video_looping = 0
  endif
  comment
    assign media_position = 0
  endcomment
  assign current_variant = product.selected_or_first_available_variant
-%}
<div class="smi-swiper-wrapper" data-current-variant="{{ current_variant.id }}">
  {% if product == nil %}
    <div class="smi-swiper-slide">
      <div class="smi-media smi-media--image smi-border smi-shadow" style="--aspect-ratio: 1; --preview-ratio: 1;">
        {{ 'product-1' | placeholder_svg_tag: 'smi-placeholder smi-w-100 smi-placeholder-light' }}
      </div>
    </div>
  {% endif %}
  {%- if current_variant.featured_media != null -%}
    {% assign current_variant_media_id = current_variant.featured_media.id %}
    {% render 'smi-product-media-item',
      media: current_variant.featured_media,
      has_thumbnail: has_thumbnail,
      icon_play: icon_play,
      icon_zoom: icon_zoom,
      icon_3d: icon_3d,
      lazy_load: 'eager',
      fetchpriority: 'high'
    %}
  {%- endif -%}
  {%- for media in product.media -%}
    {%- if media.id != current_variant_media_id -%}
      {% liquid
        if forloop.index > 1
          assign lazy_load = "lazy"
        else
          assign lazy_load = false
        endif
      %}
      {% render 'smi-product-media-item',
        media: media,
        has_thumbnail: has_thumbnail,
        icon_play: icon_play,
        icon_zoom: icon_zoom,
        icon_3d: icon_3d,
        icon_minus: icon_minus,
        icon_plus: icon_plus,
        lazy_load: lazy_load
      %}
    {%- endif -%}
  {%- endfor -%}
  {% assign VariantIdOfProduct = product.variants | map: 'id' | join: ',' %}
{% for variant in product.variants %}
  {% liquid
    assign variantIdReference = variant.id
    comment
      variant_reference
    endcomment
    assign list_variant_using_media = variant.metafields.smind.list_variants_media.value
    if list_variant_using_media
      assign variantIdReference = list_variant_using_media | map: 'id'
      assign temp = ''
      comment
        If variant id does not belong to product then delete it
      endcomment
      for variantId in variantIdReference
        if VariantIdOfProduct contains variantId
          assign temp = temp | append: ',' | append: variantId
        endif
      endfor
      assign variantIdReference = temp | remove_first: ','
      unless variantIdReference contains variant.id
        assign variantIdReference = variantIdReference | append: ',' | append: variant.id
      endunless
    endif
  %}
  {% for media in variant.metafields.smind.variant_media.value %}
    {% render 'smi-product-media-item',
            media: media,
            has_thumbnail: has_thumbnail,
            variant_id_reference: variantIdReference,
            icon_play: icon_play,
            icon_zoom: icon_zoom,
            icon_3d: icon_3d,
            lazy_load: "lazy"
    %}
  {% endfor %}
{% endfor %}
</div>
      </div>
      <div class="smi-navigation">
        <div class="smi-navigation__prev">
          {{ icon_arrow }}
        </div>
        <div class="smi-navigation__next">
          {{ icon_arrow }}
        </div>
      </div>
      {% unless section.settings.sticky_page_dot_style == 'none' %}
          {%-liquid
    if st_pagination == null 
        assign st_pagination = section.settings.sticky_page_dot_style
    endif
-%}
{% if st_pagination != 'none' %}
  {%- liquid
      assign pagination_style = 'default'
      if st_pagination contains 'text-style'
        assign pagination_style = 'fraction'
      elsif st_pagination == 'dynamic'
        assign pagination_style = 'dynamic'
      elsif st_pagination == 'scrollbar'
        assign pagination_style = 'scrollbar'
      endif
  -%}
  <div class="smi-slider-dot-container smi-pt-xl smi-w-100" data-pagination="{{ pagination_style }}">
    {%- if st_pagination contains 'text-style' -%}
      <div class="smi-component-sticky-page-dot">
        <div class="smi-slider-action">
          <div class="smi-arrows {{ st_pagination }}">
            <div data-control="textPrevSlide" class="smi-arrow dot-arrow-slider smi-text-sm">
              {% render 'smi-icons', icon: 'arrow-left' %}
            </div>
            <div class="text-pagination smi-pagination smi-slider-pagination smi-text-sm smi-arrow"></div>
            <div data-control="textNextSlide" class="smi-arrow dot-arrow-slider smi-text-sm">
              {% render 'smi-icons', icon: 'arrow-right' %}
            </div>
          </div>
        </div>
      </div>
    {%- elsif st_pagination == 'scrollbar' -%}
      <div class="smi-swiper-scrollbar"></div>
    {%- elsif st_pagination == 'dynamic' -%}
      <div class="smi-pagination"></div>
    {%- else -%}
      <div class="dot-container {{ st_pagination }}">
        <div
          class="smi-swiper-pagination smi-pagination"
          {% if st_pagination == 'dot-style-4' %}
            style="display: flex;"
          {% endif %}
        ></div>
      </div>
    {%- endif -%}
  </div>
{% endif %}
      {% endunless %}
    </div>
  </div>
</div>
</div>
        <div class="smi-block-container-2"><div class="smi-product-gallery-detail smi-gallery-{{ latestBlock }}">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'product_description' %}
        {% if block.settings.show_desc_below == true  %}
{% assign desc_no_space = product.description | strip_html | replace: '&nbsp;', '' | replace: ' ', ' ' | replace: '\u00A0', ' '
| replace: '&amp;nbsp;', '' 
| replace: '&#160;', '' 
| strip |  replace: ' ', ''  %}
{% if product.description != blank and desc_no_space != blank and desc_no_space != '' and desc_no_space != "&nbsp;" %}
	<div class="smi-d-none">bac_1234{{ desc_no_space }}</div>
  {% if block.settings.collapse_desc == true %}
    {% assign has_collapse = true %}
  {% endif %}
  {% liquid
    assign showingDesc = false
    if block.settings.collapse_desc == true and block.settings.collapse_heading != blank
      assign showingDesc = true
    endif
  %}
  <div class="smi-product-detail-element smi-w-100 smi-link-wrapper smi-mt-lg {{- ' smi-product-block-description' -}}
    {%  liquid 
      if showingDesc
        echo ' smi-block-collapse-des'
      endif
      if block.settings.show_desc_below
        echo ' smi-show-after-mob'
      endif
    %}"
    {{ block.shopify_attributes }}
  >
    {% if showingDesc %}
      <div class="smi-collapse-heading smi-d-flex smi-py-sm smi-justify-content-between smi-w-100">
        <div class="smi-text-md smi-d-flex smi-align-items-center smi-column-gap-xs" style="--svg-size: {{ block.settings.icon_size }}px;">
          {% if block.settings.upload_icon != blank %}
            {% assign sizes = block.settings.icon_size | append: 'px' %}
            {{
              block.settings.upload_icon
              | image_url: width: 300
              | image_tag: widths: '100,200,300', sizes: sizes
            }}
          {% else %}
            {% if block.settings.icon != "none" %}
              {%- render 'smi-custom-icons', icon: block.settings.icon -%}
            {% endif %}
          {% endif %}
          <h3 class="{{ block.settings.heading_size }}">{{ block.settings.collapse_heading }}</h3>
        </div>
        <div class="smi-collapse-heading__icon smi-collapse-heading__icon--arrow"></div>
