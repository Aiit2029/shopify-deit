                                            {%- endif -%}
                                          </div>
                                        {%- else -%} 
                                          <div class="smi-custom-radio smi-variant smi-d-flex smi-align-items-center smi-column-gap-sm smi-variant-wrapper smi-border-variant smi-shadow smi-px-sm {{- ' smi-py-xs' -}}
                                            {%  liquid 
                                              if sold_out_variant
                                                echo ' smi-variant-sold'
                                              endif
                                              if isSelectedVariant
                                                echo ' smi-border-variant__selected'
                                              endif
                                            %}"
                                            data-value="{{ input_id }}"
                                            data-option-index="{{ option_index }}"
                                          >
                                            {% if is_image %}
                                              <img src="{{ color_name }}" alt="{{ value |  escape |  downcase }}" class="smi-wh-100 smi-color-swatch-text smi-object-fit-cover">
                                            {%- else -%}
                                              <div class="smi-color-swatch-text" style="background: {{ color_name }}"></div>
                                            {%- endif -%}
                                            <span class="smi-text-md">{{ value }}</span>
                                          </div>
                                        {%- endif -%}
                                      {%- elsif typeSelectColor == 'variant_image' -%}
                                        {% assign variant_image = value.variant.featured_image %}
                                        <div data-smi-tooltip="{{ value }}" class="smi-custom-radio smi-variant smi-variant__color-image smi-d-flex smi-variant-wrapper smi-border-variant smi-shadow smi-px-xxs {{- ' smi-py-xxs' -}}
                                          {%  liquid 
                                            if sold_out_variant
                                              echo ' smi-variant-sold'
                                            endif
                                            if isSelectedVariant
                                              echo ' smi-border-variant__selected'
                                            endif
                                          %}"
                                          data-value="{{ input_id }}"
                                          data-option-index="{{ option_index }}"
                                        >
                                          <div class="smi-d-flex">
                                            {%- if variant_image != "" and variant_image != blank -%}
                                              {{ variant_image | image_url: width: 150 | image_tag: loading: 'lazy', class: "smi-wh-100 smi-color-image smi-object-fit-cover"}}
                                            {%- else -%}
                                              {% render 'smi-icons', icon: 'empty_imgage_variant' %}
                                            {%- endif -%}
                                          </div>
                                        </div>
                                      {%- endif -%}
                                    </label>
                                  {%- else -%}
                                    {% if is_dropdown %}
                                      <input type="radio" id="{{ input_id }}"
                                        name="{{ input_name | escape }}"
                                        value="{{ value | escape }}"
                                        form="{{ product_form_id }}"
                                        {% if value.selected %}
                                          checked
                                        {% endif %}
                                        {% if option_disabled %}
                                          class="disabled"
                                        {% endif %}
                                        {{ input_dataset }}
                                      >
                                      <label for="{{ input_id  }}">
                                        <div class="smi-custom-radio smi-custom-radio-dropdown smi-w-100 smi-text-md smi-d-flex smi-justify-content-between {{- ' smi-column-gap-xxl' -}}
                                        {% liquid
                                          if forloop.index < option.values.size 
                                            echo ' smi-mb-sm'
                                          endif
                                          unless isSelectedVariant
                                            echo ' smi-color-text-75'
                                          endunless
                                        %}"
                                        data-value="{{ input_id }}">
                                          <span>{{ value }}</span>
