      new SMI_ProductSticky(sectionElement)
    {% endif %}
    const container =  document.getElementById('smi-{{ section.id }}')
    new window.SMI_ProductHandleVariant(sectionElement, sectionId, "{% if template == 'product' %}product{% else %}featured{% endif %}")
    new window.SMI_ProductHandlePrice(sectionElement, sectionId)
    new window.SMI_ProductHandleInventory(sectionElement)
    new window.SMI_ProductHandleBuy(sectionElement, sectionId)
    new window.SMI_ProductHandleGeneral(sectionElement)
    // new SMI_COMPLEMANTARY_PRODUCT("smi-{{ section.id }}");
    if(container.querySelector(`.smi-recommend-extend-products`)){
      new window.SMI_ProductRecommendFetch(sectionElement, sectionId)
    }
    if(container.querySelector(`.smi-collapse-heading`)){
      new SMI_Collapse(container)
    }
  }, ['SMI_ProductGallery2'])
