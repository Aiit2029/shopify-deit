    {% when 'product_price' %}
{% liquid
  assign target = product.selected_or_first_available_variant
  assign compare_at_price = target.compare_at_price | times: 1
  assign price = target.price | default: 1999 | times: 1
  assign money_price = price | money
  if settings.currency_code_enabled
    assign money_price = price | money_with_currency
  endif
  if target == product and product.price_varies
    assign money_price = 'products.product.price.from_price_html' | t: price: money_price
  endif
  assign currency_code_enabled = settings.smi_currency_code_enabled | default: shop.metafields.smind.settings.value.showCurrencyCode | default: false
  if product == nil
    assign price = 0
  endif
  if currency_code_enabled
    assign currency_full = true
    assign compare_price = compare_at_price | json | money_with_currency
    assign orgin_price = price | json | money_with_currency
  else
    assign currency_full = false
    assign compare_price = compare_at_price | json | money
    assign orgin_price = price | json | money
  endif
  assign sale_percent = compare_at_price | minus: price | times: 100.0 | divided_by: compare_at_price | round | append: '%'
  if compare_at_price == 0 or compare_at_price == price
    assign sale_percent = '0%'
  endif
  if currency_full
    assign sale_amount = compare_at_price | minus: price | json | money_with_currency
  else
    assign sale_amount = compare_at_price | minus: price | json | money
  endif
  if target.inventory_quantity <= 0 and target.available == false
    assign is_sold = true
  else 
    assign is_sold = false
  endif
  if product == nil
    assign is_sold = true
  endif
%}
<div class="smi-product-detail-element smi-product-price smi-pbg-info smi-w-100 smi-mt-lg smi-custom-badge-color smi-product-price-{{ section.id }}"
  {{ block.shopify_attributes }}
  data-badge="{{ 'smind.product.sale' | t: sale_percent: sale_percent, sale_amount: sale_amount }}"
