<link rel="stylesheet" type="text/css" href="{{ 'smi-product-detail-2.min.css' | asset_url }}" media="screen" onload="this.onload=null;this.media='all'">
<link rel="stylesheet" type="text/css" href="{{ 'smi-product-card.min.css' | asset_url }}" media="screen" onload="this.onload=null;this.media='all'">
<link rel="stylesheet" type="text/css" href="{{ 'smi-swiper-bundle-v11.min.css' | asset_url }}" media="screen" onload="this.onload=null;this.media='all'">
