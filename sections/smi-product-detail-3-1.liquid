  window.smind.initializeWhenReady(()=>{
    const sectionElement =  document.getElementById('smi-{{ section.id }}');
    const sectionId =  '{{ section.id }}';
    const galleryContainer = sectionElement.querySelector('.smi-product-gallery');
    new SMI_ProductGallery2(galleryContainer);
