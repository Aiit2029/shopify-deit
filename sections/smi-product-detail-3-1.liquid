                                          assign color_temp = color_str | strip | split: ':'
                                          if color_temp.size == 2
                                            assign color_temp_0 = color_temp[0] | strip | escape | downcase
                                            assign color_temp_1 = color_temp[1] | strip | escape
                                            if color_name == color_temp_0
                                              if color_temp_1 contains '.jpg' or color_temp_1 contains '.JPG' or color_temp_1 contains '.png' or color_temp_1 contains '.PNG' or color_temp_1 contains '.gif' or color_temp_1 contains '.GIF' or color_temp_1 contains '.JPEG' or color_temp_1 contains '.jpeg'
