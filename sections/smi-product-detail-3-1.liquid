      if price >= compare_at_price or is_sold
        echo ' smi-d-none'
      endif
    %}
    ">
      {{- compare_price -}}
    </span>
    <span class="smi-price-element smi-sale-price smi-text-price-xl {% if is_sold %}smi-d-none{% endif %}">{{- orgin_price -}}</span>
    <div class="smi-price-element smi-sale-badge-original smi-sale-badge smi-px-sm smi-badges {{- ' smi-text-badge' -}}
      {% liquid
        if price >= compare_at_price or is_sold or block.settings.show_sale_badge == false
          echo ' smi-d-none'
        endif
      %}"
