  </div>
  <div class="smi-lite-modal smi-default-modal smi-format-content smi-section smi-modal-{{ section.id }} smi-product-detail-size-chart smi-dropdown-popup-wrapper smi-modal-lg smi-px-md smi-py-md smi-border smi-shadow {{ custom_color }}"
