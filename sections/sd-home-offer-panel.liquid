{%- assign max_width = section.settings.max_width | default: '1750px' -%}
<section id="sdh-offer-{{ section.id }}" class="sdh sdh-section" style="--sdh-max: {{ max_width | escape }};">
  <div class="sdh-wrap">
    <div class="sdh-offer">
      <div>
        <p class="sdh-kicker">{{ section.settings.eyebrow }}</p>
        <h2 class="sdh-title">{{ section.settings.heading }}</h2>
        <p class="sdh-copy">{{ section.settings.copy }}</p>
      </div>
      <div class="sdh-offer-grid" aria-label="Discount codes">
        {%- for block in section.blocks -%}
          <button class="sdh-offer-card" type="button" data-sdh-copy-code="{{ block.settings.code | escape }}" {{ block.shopify_attributes }}>
            <span class="sdh-offer-card__amount">{{ block.settings.amount }}</span>
            <span class="sdh-offer-card__code">{{ block.settings.code }}</span>
            <span class="sdh-offer-card__label">{{ block.settings.label }}</span>
          </button>
        {%- endfor -%}
      </div>
      <div class="sdh-copy-toast" data-sdh-copy-toast>{{ section.settings.toast_text }}</div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('sdh-offer-{{ section.id }}');
    if (!root || root.dataset.sdhReady === 'true') return;
    root.dataset.sdhReady = 'true';
    var toast = root.querySelector('[data-sdh-copy-toast]');
    var timeout;
    var fallbackCopy = function (text) {
      var input = document.createElement('textarea');
      input.value = text;
      input.setAttribute('readonly', '');
      input.style.position = 'fixed';
      input.style.opacity = '0';
      document.body.appendChild(input);
      input.select();
      document.execCommand('copy');
      document.body.removeChild(input);
    };
    root.querySelectorAll('[data-sdh-copy-code]').forEach(function (button) {
      button.addEventListener('click', function () {
        var code = button.getAttribute('data-sdh-copy-code');
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(code).catch(function () { fallbackCopy(code); });
        } else {
          fallbackCopy(code);
        }
        root.querySelectorAll('.sdh-offer-card').forEach(function (item) { item.classList.remove('is-copied'); });
        button.classList.add('is-copied');
        if (toast) {
          toast.textContent = '{{ section.settings.toast_text | escape }} ' + code;
          toast.classList.add('is-visible');
          clearTimeout(timeout);
          timeout = setTimeout(function () {
            toast.classList.remove('is-visible');
            button.classList.remove('is-copied');
          }, 1600);
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "SD Home Offer Panel",
  "settings": [
    {
      "type": "text",
      "id": "max_width",
      "label": "Content width",
      "default": "1750px"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Summer Home Refresh"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build the room, then apply the right code."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Click a code to copy it. SD10, SD13, and SD15 stay tied to different project sizes."
    },
    {
      "type": "text",
      "id": "toast_text",
      "label": "Copied toast text",
      "default": "Copied"
    }
  ],
  "blocks": [
    {
      "type": "offer",
      "name": "Offer",
      "settings": [
        {
          "type": "text",
          "id": "amount",
          "label": "Amount",
          "default": "10% Off"
        },
        {
          "type": "text",
          "id": "code",
          "label": "Code",
          "default": "SD10"
        },
        {
          "type": "textarea",
          "id": "label",
          "label": "Label",
          "default": "For a focused single-piece refresh."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SD Home Offer Panel"
    }
  ]
}
{% endschema %}
