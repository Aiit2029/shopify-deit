{% comment %}#component#["settings/heading","settings/layout-settings/mobile-3","settings/section-padding","blocks/background","settings/design-mode","settings/animation-settings","settings/slider-pagination-1-style"]#endcomponent#{% endcomment %}
<link rel="stylesheet" type="text/css" href="{{ 'smi-swiper-bundle.min.css' | asset_url }}" media="screen" onload="this.onload=null;this.media='all'">
<script src="{{ 'smi-swiper-bundle.min.js' | asset_url }}" defer data-id="smi-swiper-bundle.min.js"></script>
{% liquid
    if section.settings.enable_spacing_between_items == false
        assign space_between_mobile = '0px'
        assign space_between_desktop = '0px'
    else
        assign space_between_mobile = 'var(--grid-mobile-horizontal-spacing)'
        assign space_between_desktop = 'var(--grid-desktop-horizontal-spacing)'
    endif
    assign block_length = section.blocks | where: 'type', 'logo' | size
    assign slides_per_view_desktop = section.settings.number_of_columns_on_desktop
    assign slides_per_view_laptop = section.settings.number_of_columns_on_desktop | at_most: 3
    assign slides_per_view_tablet = section.settings.number_of_columns_on_desktop | at_most: 2
    assign slides_per_view_mobile = section.settings.number_of_columns_on_mobile | times: 1 | at_most: block_length
    if section.settings.enable_swipe_on_mobile == true
        if section.settings.enable_spacing_between_items == false
            assign offset_swiper_mobile = '(30px + var(--media-border-width))'
        else
            assign offset_swiper_mobile = '30px'
        endif 
    else
        assign offset_swiper_mobile = '0px'
    endif
    if block_length == slides_per_view_mobile
        assign offset_swiper_mobile = '0px'
    endif
    if section.settings.heading_alignment == 'left'
        assign classes_align_item = ' smi-justify-content-md-start'
        assign classes_align_item_xs = ' smi-justify-content-start'
    elsif section.settings.heading_alignment == 'right'
        assign classes_align_item = ' smi-justify-content-md-end'
        assign classes_align_item_xs = ' smi-justify-content-end'
    else
        assign classes_align_item = ' smi-justify-content-md-center'
        assign classes_align_item_xs = ' smi-justify-content-center'
    endif
    assign loop_index = 0
    assign imgSizes = '(max-width: 460px) calc(100vw/3), calc(100vw/' | append: section.settings.number_of_columns_on_desktop | append: ')'
%}
<style>
    {% if block_color %}
    {% endif %}
    {% assign block_color = section.blocks | where: 'type', 'color' | first %}
{% if block_color %}
    #shopify-section-{{ section.id }} .smi-color-{{ section.settings.color_scheme }}{
        --color-background: {{ block_color.settings.background_color.red }}, {{ block_color.settings.background_color.green }},{{ block_color.settings.background_color.blue }};
        {% if block_color.settings.background_gradient_color == blank %}
            --gradient-background: {{ block_color.settings.background_color }};
        {% else %}
            --gradient-background: {{ block_color.settings.background_gradient_color }};
        {% endif %}
        --color-foreground: {{ block_color.settings.text_color.red }}, {{ block_color.settings.text_color.green }},{{ block_color.settings.text_color.blue }};
        --color-subtext: {{ block_color.settings.subtext_color.red }},{{ block_color.settings.subtext_color.green }},{{ block_color.settings.subtext_color.blue }};
        --color-shadow: {{ block_color.settings.shadow_color.red }}, {{ block_color.settings.shadow_color.green }},{{ block_color.settings.shadow_color.blue }};
    }
{% endif %}
    #shopify-section-{{ section.id }}{
        --section-padding-top: {{ section.settings.padding_top }}px;
--section-padding-bottom: {{ section.settings.padding_bottom }}px;
        --heading-alignment: {%- liquid
    case  section.settings.heading_alignment
        when 'left'
         echo 'start'
        when 'right'
         echo 'end'
        else
         echo 'center'
    endcase
-%};
        --media-padding: {{ section.settings.media_padding }}px;
        --content-alignment: {{ section.settings.content_alignment }};
        --column-on-desktop: {{ slides_per_view_desktop }};
        --column-on-mobile: {{ slides_per_view_mobile }};
        --slide-per-view-desktop: {{ slides_per_view_desktop }};
        --slide-per-view-laptop: {{ slides_per_view_desktop | at_most: 3 }};
        --space-between-mobile: {{ space_between_mobile }};
        --space-between-desktop: {{ space_between_desktop }};
        --item-width-mobile: {{ slides_per_view_mobile | minus: 1 | prepend: 'calc((100% - ((' | append: ' * var(--space-between-mobile)) + ' | append: offset_swiper_mobile | append: '))/' | append: slides_per_view_mobile | append: ')' }};
        --item-width-tablet: {{ slides_per_view_tablet | minus: 1 | prepend: 'calc((100% - (' | append: ' * var(--space-between-desktop)))/' | append: slides_per_view_tablet | append: ')' }};
        --item-width-laptop: {{ slides_per_view_laptop | minus: 1 | prepend: 'calc((100% - (' | append: ' * var(--space-between-desktop)))/' | append: slides_per_view_laptop | append: ')' }};
        --item-width-desktop: {{ slides_per_view_desktop | minus: 1 | prepend: 'calc((100% - (' | append: ' * var(--space-between-desktop)))/' | append: slides_per_view_desktop | append: ')' }};
        --card-image-background: {{ section.settings.logo_background }};
    }
