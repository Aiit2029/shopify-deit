{%- assign max_width = section.settings.max_width | default: '1750px' -%}
<section class="sdh sdh-section--tight sdh-paths" style="--sdh-max: {{ max_width | escape }};" aria-label="{{ section.settings.aria_label | escape }}">
  <div class="sdh-wrap">
    <div class="sdh-paths-grid">
      {%- for block in section.blocks -%}
        <a class="sdh-path-card" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          <span class="sdh-card-media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(min-width: 1200px) 19vw, (min-width: 768px) 45vw, 92vw' }}
            {%- else -%}
              <span class="sdh-image-fallback">{{ 'collection-1' | placeholder_svg_tag }}</span>
            {%- endif -%}
          </span>
          <span class="sdh-card-body">
            <span class="sdh-label">{{ block.settings.label }}</span>
            <span class="sdh-card-title">{{ block.settings.title }}</span>
            <span class="sdh-card-caption">{{ block.settings.caption }}</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SD Home Nav Paths",
  "settings": [
    {
      "type": "text",
      "id": "max_width",
      "label": "Content width",
      "default": "1750px"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Primary shopping paths"
    }
  ],
  "blocks": [
    {
      "type": "path",
      "name": "Path card",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Main menu"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Lighting"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "Browse a primary shopping path."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SD Home Nav Paths"
    }
  ]
}
{% endschema %}
