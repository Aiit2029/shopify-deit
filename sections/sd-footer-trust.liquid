{%- liquid
  if section.settings.fullwidth
    assign container = 'container-full'
  elsif section.settings.max_width != blank
    assign container = 'bwp-container'
  else
    assign container = 'container'
  endif

  assign max_width = ''
  if section.settings.fullwidth == false and section.settings.max_width != blank
    capture max_width
      echo 'style="max-width: ' | append: section.settings.max_width | append: ';"'
    endcapture
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .sd-footer-trust-section {
    margin: {{ section.settings.margin }};
  }
{%- endstyle -%}

<section class="wpbingo-section sd-footer-trust-section wpbingo-section--{{ section.id }} overflow-hidden">
  <div class="{{ container }}" {{ max_width }}>
    <div class="sd-footer-trust" aria-label="{{ section.settings.aria_label | escape }}">
      {%- for block in section.blocks -%}
        {%- capture trust_content -%}
          <span class="sd-footer-trust__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'shipping' -%}
                <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h11v9H3z"></path><path d="M14 9h4.5l2.5 3v3h-7z"></path><path d="M5.5 18.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path><path d="M18.5 18.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path><path d="M8 15h7"></path></svg>
              {%- when 'secure' -%}
                <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="9" width="16" height="11" rx="2"></rect><path d="M8 9V7a4 4 0 0 1 8 0v2"></path><path d="M9 15l2 2 4-4"></path></svg>
              {%- when 'returns' -%}
                <svg viewBox="0 0 24 24" fill="none"><path d="M8 7h8a5 5 0 0 1 0 10H7"></path><path d="M10 4 7 7l3 3"></path><path d="M7 7h9"></path></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none"><path d="M5 13v-1a7 7 0 0 1 14 0v1"></path><path d="M5 13h3v5H5z"></path><path d="M16 13h3v5h-3z"></path><path d="M16 18c0 1.7-1.3 3-3 3h-2"></path></svg>
            {%- endcase -%}
          </span>
          <span>
            {%- if block.settings.title != blank -%}
              <span class="sd-footer-trust__title">{{ block.settings.title }}</span>
            {%- endif -%}
            {%- if block.settings.copy != blank -%}
              <span class="sd-footer-trust__copy">{{ block.settings.copy }}</span>
            {%- endif -%}
          </span>
        {%- endcapture -%}
        {%- if block.settings.link != blank -%}
          <a class="sd-footer-trust__item" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ trust_content }}</a>
        {%- else -%}
          <span class="sd-footer-trust__item" {{ block.shopify_attributes }}>{{ trust_content }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SD Footer Trust",
  "class": "wpbingo-framework",
  "settings": [
    {
      "type": "text",
      "id": "max_width",
      "label": "Width container",
      "default": "1750px"
    },
    {
      "type": "checkbox",
      "id": "fullwidth",
      "label": "Fullwidth",
      "default": false
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Margin",
      "default": "50px 0 0 0"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Store benefits"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "shipping",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "secure", "label": "Secure payment" },
            { "value": "returns", "label": "Returns" },
            { "value": "support", "label": "Support" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "copy",
          "label": "Copy",
          "default": "Free shipping over EUR50"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SD Footer Trust",
      "blocks": [
        { "type": "trust_item" },
        { "type": "trust_item" },
        { "type": "trust_item" },
        { "type": "trust_item" }
      ]
    }
  ]
}
{% endschema %}
